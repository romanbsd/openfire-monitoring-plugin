<?xml version="1.0" encoding="UTF-8"?>
<jive>
  <adminConsole>
    <port>9090</port>
    <securePort>9091</securePort>
    <interface>0.0.0.0</interface>
  </adminConsole>

  <connectionProvider>
    <className>org.jivesoftware.database.EmbeddedConnectionProvider</className>
  </connectionProvider>

  <conversation>
    <search>
      <index-enabled>true</index-enabled>
      <updateInterval>5</updateInterval>
      <opensearch>
        <host>opensearch</host>
        <port>9200</port>
        <scheme>http</scheme>
        <username></username>
        <password></password>
        <indexPrefix>monitoring</indexPrefix>
      </opensearch>
    </search>
  </conversation>

  <autosetup>
    <run>true</run>
    <locale>en</locale>
    <xmpp>
      <domain>localhost</domain>
      <fqdn>localhost</fqdn>
    </xmpp>
    <database>
      <mode>embedded</mode>
    </database>
    <admin>
      <email>admin@localhost</email>
      <password>admin</password>
    </admin>
    <authprovider>
      <mode>default</mode>
    </authprovider>
  </autosetup>
</jive>
